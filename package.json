{
  "name": "baramiz-ai-backend",
  "version": "1.0.0",
  "description": "MVP backend for the Baramiz AI tourism mini app focused on Karakalpakstan.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node -e \"const path=require('node:path'); const root=path.dirname(process.env.npm_package_json); require(path.join(root,'scripts','npm-runner.cjs')).run('dev');\"",
    "build": "node -e \"const path=require('node:path'); const root=path.dirname(process.env.npm_package_json); require(path.join(root,'scripts','npm-runner.cjs')).run('build');\"",
    "start": "node -e \"const path=require('node:path'); const root=path.dirname(process.env.npm_package_json); require(path.join(root,'scripts','npm-runner.cjs')).run('start');\""
  },
  "keywords": [
    "baramiz",
    "tourism",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.32.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
